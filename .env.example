# /vsi-ai-om/.env.example
# ===========================================
# VSI-AI-OM 环境变量配置模板
# ===========================================
# 使用方法:
#   1. 复制此文件为 .env
#   2. 修改下面的值
#   3. 在启动前加载环境变量: source .env
# ===========================================

# ===========================================
# 大模型 API 配置（必需）
# ===========================================
# 阿里云 DashScope API Key
# 获取地址：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY="your-dashscope-api-key-here"

# ===========================================
# SSH 认证配置（生产环境必需）
# ===========================================
# Jenkins SSH 私钥路径（推荐使用密钥而非密码）
JENKINS_SSH_KEY_PATH="/var/jenkins/ssh_key"

# Jenkins SSH 用户名
JENKINS_SSH_USER="jenkins-agent"

# Jenkins Agent 主机名或 IP
JENKINS_SSH_HOST="agent-host"

# SSH Known Hosts 文件路径
JENKINS_KNOWN_HOSTS_PATH="/var/jenkins/known_hosts"

# ===========================================
# LLM 模型配置（可选）
# ===========================================
# 使用的模型名称
LLM_MODEL="qwen-max"

# ===========================================
# 数据库配置（可选，默认使用 SQLite）
# ===========================================
# MCP 数据库路径
MCP_DB_PATH="/vsi-ai-om/mcp_service/problems.db"

# RAG Chroma 数据库路径
CHROMA_DB_PATH="/vsi-ai-om/rag/chroma_db"

# ===========================================
# 日志配置（可选）
# ===========================================
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL="INFO"

# 日志文件路径
LOG_FILE="/var/log/vsi-ai-om/agent.log"

# ===========================================
# 安全配置（可选但推荐）
# ===========================================
# JWT Secret（用于 API 认证，如果启用）
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# API 速率限制（每分钟最大请求数）
RATE_LIMIT_PER_MINUTE=60

# 允许的 IP 白名单（逗号分隔）
ALLOWED_IPS="127.0.0.1,192.168.1.0/24"

# ===========================================
# Docker 相关配置（仅 Docker 部署需要）
# ===========================================
# Docker Compose 项目名称
COMPOSE_PROJECT_NAME="vsi-ai-om"

# 服务端口
MCP_SERVICE_PORT=8000
AGENT_SERVICE_PORT=8001

# ===========================================
# 其他配置
# ===========================================
# 是否启用调试模式（生产环境必须设为 false）
DEBUG=false

# 运行环境：development, staging, production
ENVIRONMENT="production"
